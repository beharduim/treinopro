{
  "name": "protraining-api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest --config ./test/jest.config.js",
    "test:watch": "jest --config ./test/jest.config.js --watch",
    "test:cov": "jest --config ./test/jest.config.js --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --config ./test/jest.config.js --runInBand",
    "test:unit": "jest --config ./test/jest.config.js --testPathPattern=spec.ts",
    "test:auth": "jest --config ./test/jest.config.js --testPathPattern=auth",
    "test:integration": "jest --config ./test/integration/jest.config.js",
    "test:integration:auth": "jest --config ./test/integration/jest.config.js --testPathPattern=auth",
    "test:integration:db": "jest --config ./test/integration/jest.config.js --testPathPattern=database",
    "test:all": "yarn test:unit && yarn test:integration",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "db:generate": "drizzle-kit generate:pg",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push:pg",
    "migrate:admin": "node scripts/migrate-admin-user-type-drizzle.js",
    "migrate:admin:simple": "node scripts/migrate-admin-simple.js",
    "migrate:admin:api": "curl -X POST http://localhost:3000/admin-migration/add-admin-user-type"
  },
  "dependencies": {
    "@bull-board/api": "^6.12.7",
    "@bull-board/express": "^6.12.7",
    "@bull-board/nestjs": "^6.12.7",
    "@bull-board/ui": "^6.12.7",
    "@nestjs/bull": "^11.0.3",
    "@nestjs/cache-manager": "^2.1.1",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/platform-socket.io": "^10.2.8",
    "@nestjs/schedule": "^6.0.1",
    "@nestjs/swagger": "^7.1.17",
    "@nestjs/websockets": "^10.2.8",
    "@types/multer": "^2.0.0",
    "axios": "^1.12.0",
    "bcryptjs": "^2.4.3",
    "bull": "^4.16.5",
    "cache-manager": "^5.2.4",
    "cache-manager-redis-store": "^3.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "drizzle-kit": "^0.20.6",
    "drizzle-orm": "^0.29.0",
    "firebase-admin": "^13.5.0",
    "form-data": "^4.0.5",
    "mercadopago": "^2.9.0",
    "multer": "^2.0.2",
    "node-curl-impersonate": "^1.5.4",
    "nodemailer": "^7.0.6",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "postgres": "^3.4.3",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "sharp": "^0.34.5",
    "socket.io": "^4.7.4",
    "undici": "^7.16.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/bull": "^4.10.4",
    "@types/caseless": "^0.12.5",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/long": "^5.0.0",
    "@types/mercadopago": "^1.5.11",
    "@types/node": "^20.3.1",
    "@types/nodemailer": "^7.0.1",
    "@types/passport-jwt": "^3.0.13",
    "@types/passport-local": "^1.0.38",
    "@types/request": "^2.48.13",
    "@types/supertest": "^6.0.0",
    "@types/tough-cookie": "^4.0.5",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
